# ============================================
# 环境变量配置示例
# 复制此文件为 .env.local 并填入真实值（.env.local 不会提交到 Git）
# ============================================

# AI 对话代理 URL（推荐：阿里云函数计算 FC）
# 后端代理负责调用阿里云通义千问 DashScope API
# 例如：https://your-fc-url.aliyuncs.com/chat
NEXT_PUBLIC_CHAT_PROXY_URL=

# 图像生成代理 URL（通义万相）
NEXT_PUBLIC_IMAGE_PROXY_URL=

# 树洞投稿后端（Supabase / 自建 API）
NEXT_PUBLIC_STORIES_API_URL=

# 模型选择
NEXT_PUBLIC_CHAT_MODEL=qwen-max
NEXT_PUBLIC_IMAGE_MODEL=wanx-v1

# ============================================
# GitHub Pages 部署配置
# ============================================
# 如果你的 GitHub Pages 部署在 https://username.github.io（用户主页仓库），留空
# 如果部署在 https://username.github.io/repo-name，填仓库名（不带斜杠）
# GITHUB_REPO=xiaoyeningtiao.github.io
